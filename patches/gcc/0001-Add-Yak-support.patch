From 1c9e7446f20483293ad7847d2837129eab512a87 Mon Sep 17 00:00:00 2001
From: Vincent Schweiger <vinsch32@icloud.com>
Date: Sat, 28 Feb 2026 18:51:06 +0100
Subject: [PATCH] Add Yak support

---
 fixincludes/mkfixinc.sh |  1 +
 gcc/config.build        |  2 +-
 gcc/config.gcc          | 12 ++++++++++++
 gcc/config/i386/yak.h   |  7 +++++++
 gcc/config/yak.h        | 22 ++++++++++++++++++++++
 gcc/cp/module.cc        |  4 ++++
 libatomic/configure.tgt |  2 +-
 libgcc/config.host      | 18 ++++++++++++++++++
 8 files changed, 66 insertions(+), 2 deletions(-)
 create mode 100644 gcc/config/i386/yak.h
 create mode 100644 gcc/config/yak.h

diff --git a/fixincludes/mkfixinc.sh b/fixincludes/mkfixinc.sh
index 7112f4dcd..56aecde19 100755
--- a/fixincludes/mkfixinc.sh
+++ b/fixincludes/mkfixinc.sh
@@ -13,6 +13,7 @@ target=fixinc.sh
 case $machine in
     i?86-*-cygwin* | \
     *-mingw32* | \
+    *-yak* | \
     powerpc-*-eabisim* | \
     powerpc-*-eabi*    | \
     powerpc-*-rtems*   | \
diff --git a/gcc/config.build b/gcc/config.build
index 7c80a0b7a..8fac7e4df 100644
--- a/gcc/config.build
+++ b/gcc/config.build
@@ -45,7 +45,7 @@
 build_xm_file=
 build_xm_defines=
 build_exeext=
-build_install_headers_dir=install-headers-tar
+build_install_headers_dir=install-headers-cp
 build_file_translate=
 
 # System-specific settings.
diff --git a/gcc/config.gcc b/gcc/config.gcc
index 087aaa7be..251c3cc34 100644
--- a/gcc/config.gcc
+++ b/gcc/config.gcc
@@ -885,6 +885,15 @@ case ${target} in
   rust_target_objs="${rust_target_objs} fuchsia-rust.o"
   target_has_targetrustm=yes
   ;;
+*-*-*-mlibc)
+  extra_options="$extra_options gnu-user.opt"
+  gas=yes
+  gnu_ld=yes
+  tmake_file="$tmake_file t-slibgcc"
+  default_use_cxa_atexit=yes
+  use_gcc_stdint=wrap
+  thread_file='posix'
+  ;;
 *-*-linux* | frv-*-*linux* | *-*-kfreebsd*-gnu | *-*-gnu* | *-*-kopensolaris*-gnu | *-*-uclinuxfdpiceabi)
   extra_options="$extra_options gnu-user.opt"
   gas=yes
@@ -2067,6 +2076,9 @@ i[34567]86-*-linux* | i[34567]86-*-kfreebsd*-gnu | i[34567]86-*-gnu* | i[34567]8
 		;;
 	esac
 	;;
+x86_64-*-yak*)
+	tm_file="${tm_file} i386/unix.h i386/att.h elfos.h gnu-user.h glibc-stdint.h i386/x86-64.h i386/gnu-user-common.h i386/gnu-user64.h yak.h i386/yak.h"
+	;;
 x86_64-*-linux* | x86_64-*-kfreebsd*-gnu | x86_64-*-gnu*)
 	tm_file="${tm_file} i386/unix.h i386/att.h elfos.h gnu-user.h glibc-stdint.h \
 		 i386/x86-64.h i386/gnu-user-common.h i386/gnu-user64.h"
diff --git a/gcc/config/i386/yak.h b/gcc/config/i386/yak.h
new file mode 100644
index 000000000..a43f312f4
--- /dev/null
+++ b/gcc/config/i386/yak.h
@@ -0,0 +1,7 @@
+#define GNU_USER_LINK_EMULATION32 "elf_i386"
+#define GNU_USER_LINK_EMULATION64 "elf_x86_64"
+#define GNU_USER_LINK_EMULATIONX32 "elf32_x86_64"
+
+#define GNU_USER_DYNAMIC_LINKER32 "/does_not_exist"
+#define GNU_USER_DYNAMIC_LINKER64 "/usr/lib/ld.so"
+#define GNU_USER_DYNAMIC_LINKERX32 "/does_not_exist"
diff --git a/gcc/config/yak.h b/gcc/config/yak.h
new file mode 100644
index 000000000..39a353924
--- /dev/null
+++ b/gcc/config/yak.h
@@ -0,0 +1,22 @@
+#undef TARGET_YAK
+#define TARGET_YAK 1
+
+#undef LIB_SPEC
+#define LIB_SPEC "-lc"
+
+#undef STARTFILE_SPEC
+#define STARTFILE_SPEC "%{!shared: %{static-pie|pie|!no-pie:Scrt1.o%s;:crt1.o%s}} crti.o%s %{shared|static-pie|pie|!no-pie:crtbeginS.o%s;:crtbegin.o%s}"
+
+#undef ENDFILE_SPEC
+#define ENDFILE_SPEC "%{shared|static-pie|pie|!no-pie:crtendS.o%s;:crtend.o%s} crtn.o%s"
+
+#undef TARGET_OS_CPP_BUILTINS
+#define TARGET_OS_CPP_BUILTINS()            	\
+	do {					\
+		builtin_define ("__yak__"); 	\
+		builtin_define ("__mlibc__");	\
+		builtin_define ("__unix__");	\
+		builtin_assert ("system=yak");	\
+		builtin_assert ("system=unix");	\
+		builtin_assert ("system=posix");\
+	} while (0);
diff --git a/gcc/cp/module.cc b/gcc/cp/module.cc
index 1deadcc18..8c7fbe4f3 100644
--- a/gcc/cp/module.cc
+++ b/gcc/cp/module.cc
@@ -1697,8 +1697,10 @@ elf_in::defrost (const char *name)
 	      set_error (errno);
 	  else
 	    {
+#ifndef __yak__
 	      if (madvise (mapping, hdr.pos, MADV_RANDOM))
 		goto fail;
+#endif
 
 	      /* These buffers are never NULL in this case.  */
 	      strtab.buffer = mapping + strtab.pos;
@@ -1808,8 +1810,10 @@ elf_in::begin (location_t loc)
     }
   /* We'll be hopping over this randomly.  Some systems declare the
      first parm as char *, and other declare it as void *.  */
+#ifndef __yak__
   if (madvise (reinterpret_cast <char *> (mapping), size, MADV_RANDOM))
     goto fail;
+#endif
 
   hdr.buffer = (char *)mapping;
 #else
diff --git a/libatomic/configure.tgt b/libatomic/configure.tgt
index 6db039d6e..e4fc3911d 100644
--- a/libatomic/configure.tgt
+++ b/libatomic/configure.tgt
@@ -151,7 +151,7 @@ case "${target}" in
   *-*-linux* | *-*-gnu* | *-*-k*bsd*-gnu \
   | *-*-netbsd* | *-*-freebsd* | *-*-openbsd* | *-*-dragonfly* \
   | *-*-solaris2* | *-*-sysv4* | *-*-irix6* | *-*-osf* | *-*-hpux11* \
-  | *-*-darwin* | *-*-aix* | *-*-cygwin*)
+  | *-*-darwin* | *-*-aix* | *-*-cygwin* | *-*-mlibc*)
 	# POSIX system.  The OS is supported.
 	config_path="${config_path} posix"
 	;;
diff --git a/libgcc/config.host b/libgcc/config.host
index 6a88ee5a2..e739d2ac3 100644
--- a/libgcc/config.host
+++ b/libgcc/config.host
@@ -310,6 +310,16 @@ case ${host} in
   tmake_file="$tmake_file t-crtstuff-pic t-libgcc-pic t-eh-dw2-dip t-slibgcc t-slibgcc-fuchsia"
   extra_parts="crtbegin.o crtend.o"
   ;;
+*-*-*-mlibc)
+  extra_parts="$extra_parts crtbegin.o crtbeginS.o crtend.o crtendS.o"
+  tmake_file="$tmake_file t-crtstuff-pic t-slibgcc t-slibgcc-gld t-slibgcc-elf-ver t-libgcc-pic"
+  ;;
+*-*-yak-kernel)
+  extra_parts="$extra_parts crtbegin.o crtbeginS.o crtend.o crtendS.o"
+  extra_parts="$extra_parts crti.o crtn.o"
+  tmake_file="$tmake_file t-crtstuff-pic"
+  tmake_file="$tmake_file t-slibgcc t-slibgcc-gld t-slibgcc-elf-ver t-libgcc-pic"
+  ;;
 *-*-linux* | frv-*-*linux* | *-*-kfreebsd*-gnu | *-*-gnu* | *-*-kopensolaris*-gnu | *-*-uclinuxfdpiceabi)
   tmake_file="$tmake_file t-crtstuff-pic t-libgcc-pic t-eh-dw2-dip t-slibgcc t-slibgcc-gld t-slibgcc-elf-ver t-linux"
   extra_parts="crtbegin.o crtbeginS.o crtbeginT.o crtend.o crtendS.o"
@@ -771,6 +781,14 @@ i[34567]86-*-dragonfly*)
 	tmake_file="${tmake_file} i386/t-dragonfly i386/t-crtstuff"
 	md_unwind_header=i386/dragonfly-unwind.h
 	;;
+x86_64-*-*-mlibc)
+	extra_parts="$extra_parts crtprec32.o crtprec64.o crtprec80.o crtfastmath.o"
+	tmake_file="${tmake_file} i386/t-crtpc t-crtfm i386/t-crtstuff t-dfprules"
+	;;
+x86_64-*-yak-kernel)
+	extra_parts="$extra_parts crtprec32.o crtprec64.o crtprec80.o crtfastmath.o"
+	tmake_file="${tmake_file} i386/t-crtpc t-crtfm i386/t-crtstuff t-dfprules"
+	;;
 x86_64-*-dragonfly*)
 	tmake_file="${tmake_file} i386/t-dragonfly i386/t-crtstuff"
 	md_unwind_header=i386/dragonfly-unwind.h
-- 
2.52.0

