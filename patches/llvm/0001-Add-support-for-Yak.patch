@@ -1457,6 +1457,18 @@ TEST(TripleTest, ParsedIDs) {
   EXPECT_EQ(Triple::Managarm, T.getOS());
   EXPECT_EQ(Triple::Mlibc, T.getEnvironment());
 
+  T = Triple("x86_64-unknown-yak-mlibc");
+  EXPECT_EQ(Triple::x86_64, T.getArch());
+  EXPECT_EQ(Triple::UnknownVendor, T.getVendor());
+  EXPECT_EQ(Triple::Yak, T.getOS());
+  EXPECT_EQ(Triple::Mlibc, T.getEnvironment());
+
+  T = Triple("riscv64-unknown-yak-mlibc");
+  EXPECT_EQ(Triple::riscv64, T.getArch());
+  EXPECT_EQ(Triple::UnknownVendor, T.getVendor());
+  EXPECT_EQ(Triple::Yak, T.getOS());
+  EXPECT_EQ(Triple::Mlibc, T.getEnvironment());
